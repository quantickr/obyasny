# === База данных ===
POSTGRES_USER=connectstudents
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=connectstudents
# Внутри docker-compose host = db. Локально без докера — localhost.
DATABASE_URL=postgresql+asyncpg://connectstudents:change_me_in_prod@db:5432/connectstudents

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Telegram ===
# Токен от @BotFather
BOT_TOKEN=123456:PLACEHOLDER_GET_FROM_BOTFATHER
# username бота без @ (для deep-link t.me/<username>?start=code)
BOT_USERNAME=YourBot

# === Веб-приложение ===
# Базовый публичный URL сайта (для ссылок в боте и Telegram Login)
WEBAPP_BASE_URL=http://localhost:8000
# Секрет для подписи JWT/сессий (сгенерировать: openssl rand -hex 32)
JWT_SECRET=change_me_super_secret_key
# Время жизни сессии в часах
SESSION_TTL_HOURS=168

# === Прочее ===
# Домен для прод-деплоя (используется в docker-compose.prod.yml / nginx)
DOMAIN=example.com
# Email для выпуска TLS-сертификата Let's Encrypt (уведомления о продлении)
EMAIL=admin@example.com
